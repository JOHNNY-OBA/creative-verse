generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // hashed with argon2
  name      String
  status    String   @default("active") // active, suspended
  createdAt DateTime @default(now())
}
enum Role {
  USER
  Admin
}
model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}